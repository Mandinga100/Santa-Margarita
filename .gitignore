# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# firebase
.firebase/
firebase-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project backups
/backup/

# large media files (>100MB - GitHub limit)
*.mp4
*.mov
*.avi
*.mkv
/video/

# scraper output (datos generados en runtime, no versionar)
obituarios_eticos.json
scraper_etico.log
audit_hash.txt
